    },
    {
      "name": "clang-libc++-release",
      "displayName": "Clang-libc++ Release: configure, build, test",
      "description": "Full local/CI loop for Clang + libc++ RelWithDebInfo.",
      "steps": [
        {
          "type": "configure",
          "name": "clang-libc++-release"
        },
        {
