        }
      ]
    },
    {
      "name": "msvc-debug",
      "displayName": "MSVC Debug: configure, build, test",
      "description": "Full local/CI loop for MSVC Debug.",
      "steps": [
        {
          "type": "configure",
          "name": "msvc-debug"
        },
        {
          "type": "build",
          "name": "msvc-debug"
        },
        {
          "type": "test",
          "name": "msvc-debug"
        }
      ]
    },
    {
      "name": "msvc-release",
      "displayName": "MSVC Release: configure, build, test",
      "description": "Full local/CI loop for MSVC RelWithDebInfo.",
      "steps": [
        {
          "type": "configure",
          "name": "msvc-release"
        },
        {
