{
  "$schema": "https://raw.githubusercontent.com/Kitware/CMake/master/Help/manual/presets/schema.json",
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "description": "Shared generator, output dir, and portable CMake defaults.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "warnings": {
        "dev": true,
        "deprecated": true,
        "unusedCli": true
      },
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "26",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_COLOR_DIAGNOSTICS": "ON",
        "CMAKE_WARN_DEPRECATED": "ON",
        "CMAKE_LINK_WHAT_YOU_USE": "ON",
        "CMAKE_PROJECT_TOP_LEVEL_INCLUDES": "./devenv/cmake/fetch-content-from-lockfile.cmake"
      }
    },
    {
      "name": "debug",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "gcc",
      "hidden": true,
      "toolchainFile": "devenv/cmake/toolchains/gcc-toolchain.cmake"
    },
    {
      "name": "clang",
      "hidden": true,
      "toolchainFile": "devenv/cmake/toolchains/clang-toolchain.cmake"
    },
    {
      "name": "clang-libc++",
      "hidden": true,
      "toolchainFile": "devenv/cmake/toolchains/clang-libc++-toolchain.cmake"
    },
    {
      "name": "appleclang",
      "hidden": true,
      "toolchainFile": "devenv/cmake/toolchains/appleclang-toolchain.cmake",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "23"
      }
    },
    {
      "name": "msvc",
      "hidden": true,
      "toolchainFile": "devenv/cmake/toolchains/msvc-toolchain.cmake",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "23"
      }
    },
    {
      "name": "MaxSan",
      "hidden": true,
      "cacheVariables": {
        "MB_DEVENV_SANITIZER": "MaxSan"
      }
    },
    {
      "name": "TSan",
      "hidden": true,
      "cacheVariables": {
        "MB_DEVENV_SANITIZER": "TSan"
      }
    },
    {
      "name": "MSan",
      "hidden": true,
      "cacheVariables": {
        "MB_DEVENV_SANITIZER": "MSan"
      }
    },
    {
      "name": "gcc-debug",
      "displayName": "GCC Debug Build",
      "description": "Ninja + GCC toolchain, Debug.",
      "inherits": [
        "gcc",
        "debug",
        "base"
      ]
    },
    {
      "name": "gcc-release",
      "displayName": "GCC Release Build",
      "description": "Ninja + GCC toolchain, RelWithDebInfo.",
      "inherits": [
        "gcc",
        "release",
        "base"
      ]
    },
    {
      "name": "clang-debug",
      "displayName": "Clang Debug Build",
      "description": "Ninja + Clang (libstdc++), Debug.",
      "inherits": [
        "clang",
        "debug",
        "base"
      ]
    },
    {
      "name": "clang-release",
      "displayName": "Clang Release Build",
      "description": "Ninja + Clang (libstdc++), RelWithDebInfo.",
      "inherits": [
        "clang",
        "release",
        "base"
      ]
    },
    {
      "name": "clang-libc++-debug",
      "displayName": "Clang-libc++ Debug Build",
      "description": "Ninja + Clang + libc++, Debug.",
      "inherits": [
        "clang-libc++",
        "debug",
        "base"
      ]
    },
    {
      "name": "clang-libc++-release",
      "displayName": "Clang-libc++ Release Build",
      "description": "Ninja + Clang + libc++, RelWithDebInfo.",
      "inherits": [
        "clang-libc++",
        "release",
        "base"
      ]
    },
    {
      "name": "clang-libc++-maxwarn-release",
      "displayName": "Clang-libc++ MaxSan MaxWarn Release Build",
      "description": "Ninja + Clang + libc++, RelWithDebInfo. Duplicates mb_ul_set_target_warnings Clang (non-Debug) compile options via global CMAKE_CXX_FLAGS so they apply project-wide; this can break builds that pull in third-party sources (e.g. FetchContent) that do not compile cleanly under -Werror and the rest. Adds -Wno-unused-command-line-argument so globally ignored -f flags on some platforms do not fail the build.",
      "inherits": [
        "clang-libc++",
        "MaxSan",
        "release",
        "base"
      ],
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-D_GLIBCXX_ASSERTIONS -fexceptions -fno-builtin -fstack-clash-protection -fstack-protector-strong -U_FORTIFY_SOURCE -D_FORTIFY_SOURCE=3 -fno-delete-null-pointer-checks -fno-strict-overflow -fno-strict-aliasing -fno-limit-debug-info -fstrict-flex-arrays=3 -Wall -Wconversion -Werror -Wextra -Wformat -Wformat=2 -Wimplicit-fallthrough -Wno-deprecated-declarations -Wpedantic -Wsign-conversion -Wdocumentation -Wmissing-prototypes -Wno-c++11-narrowing -Wno-c++20-compat -Wno-switch-default -Wno-unused-command-line-argument",
        "MB_UL_ALL_WARNINGS": "ON"
      }
    },
    {
      "name": "clang-libc++-allwarn-release",
      "displayName": "Clang-libc++ MaxSan MaxWarn+AllWarn Release Build",
      "description": "Same as clang-libc++-maxwarn-release (MaxSan, global mb_ul_set_target_warnings-style CMAKE_CXX_FLAGS, MB_UL_ALL_WARNINGS) plus the Clang -Weverything bundle appended to CMAKE_CXX_FLAGS so it applies to every translation unit, including third-party/FetchContent. Sets MB_UL_ALL_WARNINGS=OFF so mb_ul_set_target_warnings does not add the same -Weverything flags again on project targets (avoids duplicate warning options). Flag list matches cmake/cmake-util/defaults.cmake (MB_UL_ALL_WARNINGS branch).",
      "inherits": [
        "clang-libc++-maxwarn-release"
      ],
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-D_GLIBCXX_ASSERTIONS -fexceptions -fno-builtin -fstack-clash-protection -fstack-protector-strong -U_FORTIFY_SOURCE -D_FORTIFY_SOURCE=3 -fno-delete-null-pointer-checks -fno-strict-overflow -fno-strict-aliasing -fno-limit-debug-info -fstrict-flex-arrays=3 -Wall -Wconversion -Werror -Wextra -Wformat -Wformat=2 -Wimplicit-fallthrough -Wno-deprecated-declarations -Wpedantic -Wsign-conversion -Wdocumentation -Wmissing-prototypes -Wno-c++11-narrowing -Wno-c++20-compat -Wno-switch-default -Wno-unused-command-line-argument -Weverything -Wmissing-prototypes -Wno-c++98-compat -Wno-c++98-compat-pedantic -Wno-covered-switch-default -Wno-deprecated -Wno-double-promotion -Wno-exit-time-destructors -Wno-global-constructors -Wno-missing-noreturn -Wno-padded -Wno-redundant-parens -Wno-shadow-field-in-constructor -Wno-switch-enum -Wno-undef -Wno-undefined-reinterpret-cast -Wno-unused-member-function -Wno-weak-vtables",
        "MB_UL_ALL_WARNINGS": "OFF"
      }
    },
    {
      "name": "appleclang-debug",
      "displayName": "Appleclang Debug Build",
      "description": "Ninja + Apple Clang, Debug.",
      "inherits": [
        "appleclang",
        "debug",
        "base"
      ]
    },
    {
      "name": "appleclang-release",
      "displayName": "Appleclang Release Build",
      "description": "Ninja + Apple Clang, RelWithDebInfo.",
      "inherits": [
        "appleclang",
        "release",
        "base"
      ]
    },
    {
      "name": "msvc-debug",
      "displayName": "MSVC Debug Build",
      "description": "Ninja + MSVC, Debug.",
      "inherits": [
        "msvc",
        "debug",
        "base"
      ]
    },
    {
      "name": "msvc-release",
      "displayName": "MSVC Release Build",
      "description": "Ninja + MSVC, RelWithDebInfo.",
      "inherits": [
        "msvc",
        "release",
        "base"
      ]
    }
  ],
