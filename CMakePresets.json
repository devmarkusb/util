          "name": "clang-libc++-release"
        },
        {
          "type": "test",
          "name": "clang-libc++-release"
        }
      ]
    },
    {
      "name": "appleclang-debug",
      "displayName": "Apple Clang Debug: configure, build, test",
      "description": "Full local/CI loop for Apple Clang Debug.",
      "steps": [
        {
          "type": "configure",
          "name": "appleclang-debug"
        },
        {
